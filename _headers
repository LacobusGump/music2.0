# Block .md files from being served
/*.md
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

# Security headers for everything
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# JS/CSS are edited in place under stable names (playlist.js, breathe.js…),
# so they must NOT be immutable — that would pin old copies for up to a year.
# no-cache = browsers still store the file but revalidate every load via ETag;
# unchanged files return a cheap 304, edited files propagate immediately.
# This removes the need to hand-bump ?v=N on every page reference.
/js/*
  Cache-Control: public, no-cache
/css/*
  Cache-Control: public, no-cache

# The favicon never changes meaningfully — safe to cache hard.
/favicon.png
  Cache-Control: public, max-age=31536000, immutable
